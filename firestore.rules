rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ===============================================================
    // Helper Functions
    // ===============================================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && 
        (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin' ||
         (request.auth.token.email == "limadan389@gmail.com" && request.auth.token.email_verified == true));
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isPartner() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'partner';
    }

    function isDriver() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'driver';
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // User Profiles
    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && request.auth.uid == userId && 
                    request.resource.data.role == 'customer';
      allow update: if isOwner(userId) && 
                    request.resource.data.role == resource.data.role; // Cannot change own role
    }

    // Condominiums
    match /condominiums/{condoId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Partners
    match /partners/{partnerId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Products (Generic Catalog)
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Product Variations (Brand/Price/Partner specific)
    match /productVariations/{variationId} {
      allow read: if true;
      allow write: if isAdmin() || (isPartner() && request.resource.data.partnerId == request.auth.uid);
    }

    // Orders
    match /orders/{orderId} {
      allow read: if isAuthenticated() && (
        request.auth.uid == resource.data.userId || 
        isAdmin() || 
        (isPartner() && request.auth.uid == resource.data.partnerId)
      );
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin() || (isPartner() && request.auth.uid == resource.data.partnerId);
      
      // Order Items
      match /items/{itemId} {
        allow read: if isAuthenticated() && (
          get(/databases/$(database)/documents/orders/$(orderId)).data.userId == request.auth.uid || 
          isAdmin() || 
          isPartner()
        );
        allow write: if isAuthenticated() && (
          get(/databases/$(database)/documents/orders/$(orderId)).data.userId == request.auth.uid || 
          isAdmin()
        );
      }
    }

    // Deliveries
    match /deliveries/{deliveryId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isDriver();
    }

    // Drivers
    match /drivers/{driverId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Admin Logs
    match /adminLogs/{logId} {
      allow read, write: if isAdmin();
    }
  }
}
